# Issue tracker target: "github" (default) or "jira"
TARGET=github

# LLM provider: "openai" (default) or "anthropic"
LLM_PROVIDER=openai

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic / Claude (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# GitHub (required when TARGET=github)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Jira Cloud (required when TARGET=jira)
JIRA_HOST=your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
